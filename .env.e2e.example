# ============================================================
# Drawlatch E2E Tests — Environment Variables
# ============================================================
# Copy to .env.e2e and fill in values for the connections you
# want to test. Tests for connections with missing env vars
# will be skipped automatically.
# ============================================================

# ------------------------------------------------------------
# GitHub (webhook simulation — no public URL needed)
# ------------------------------------------------------------
# PAT with repo access (used by test_connection verification)
GITHUB_TOKEN=
# Arbitrary shared secret for signing simulated webhook payloads
GITHUB_WEBHOOK_SECRET=e2e-test-secret

# ------------------------------------------------------------
# Discord Bot (real Gateway WebSocket connection)
# ------------------------------------------------------------
# Bot token with MESSAGE_CONTENT intent enabled
DISCORD_BOT_TOKEN=
# Channel ID to send a test message to (bot must have access)
DISCORD_E2E_CHANNEL_ID=
# Guild ID the test channel belongs to
DISCORD_E2E_GUILD_ID=

# ------------------------------------------------------------
# Trello (webhook simulation — no public URL needed)
# ------------------------------------------------------------
# API key and token (used by test_connection verification)
TRELLO_API_KEY=
TRELLO_TOKEN=
# Arbitrary shared secret for signing simulated webhook payloads
TRELLO_API_SECRET=e2e-test-secret
